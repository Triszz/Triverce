// Prisma schema for Ecommerce-Project backend
// Translated from the original db-migrate SQL migrations (migrations/*.js).
// Connection URLs live in prisma.config.ts (Prisma 7+).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────
// Enums (mirror the original CHECK constraints)
// ──────────────────────────────────────────────────────────────

enum UserRole {
  customer
  admin
  seller

  @@map("user_role")
}

enum CartStatus {
  active
  checked_out
  abandoned

  @@map("cart_status")
}

enum OrderStatus {
  pending
  confirmed
  shipping
  delivered
  cancelled
  failed

  @@map("order_status")
}

enum PaymentStatus {
  pending
  processing
  paid
  failed
  cancelled
  refunded

  @@map("payment_status")
}

enum PaymentGateway {
  momo
  stripe
  vnpay
  cod

  @@map("payment_gateway")
}

// ──────────────────────────────────────────────────────────────
// Users
// ──────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @default("") @map("full_name") @db.VarChar(255)
  role         UserRole  @default(customer)
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Self-referential seller → products
  products            Product[]        @relation("SellerProducts")
  carts               Cart[]
  ordersAsCustomer    Order[]          @relation("CustomerOrders")
  ordersAsSeller      Order[]          @relation("SellerOrders")
  payments            Payment[]
  orderStatusLogs     OrderStatusLog[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

// ──────────────────────────────────────────────────────────────
// Catalog: categories, products, variants, attributes
// ──────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?
  parentId    String?    @map("parent_id") @db.Uuid
  isActive    Boolean    @default(true) @map("is_active")
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId], map: "idx_categories_parent_id")
  @@map("categories")
}

model Product {
  id          String    @id @default(uuid()) @db.Uuid
  categoryId  String?   @map("category_id") @db.Uuid
  sellerId    String    @map("seller_id") @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?
  basePrice   Decimal   @map("base_price") @db.Decimal(12, 2)
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  category Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  seller   User            @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Restrict)
  variants ProductVariant[]

  @@index([categoryId], map: "idx_products_category_id")
  @@index([isActive], map: "idx_products_is_active")
  @@index([sellerId], map: "idx_products_seller_id")
  @@map("products")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  values VariantAttributeValue[]

  @@map("product_attributes")
}

model ProductVariant {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  sku       String   @unique @db.VarChar(100)
  price     Decimal  @db.Decimal(12, 2)
  imageUrl  String?  @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  product             Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory           Inventory?
  attributeValues     VariantAttributeValue[]
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([productId], map: "idx_product_variants_product_id")
  @@map("product_variants")
}

model VariantAttributeValue {
  variantId   String   @map("variant_id") @db.Uuid
  attributeId String   @map("attribute_id") @db.Uuid
  value       String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  variant   ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Restrict)

  @@id([variantId, attributeId])
  @@index([attributeId], map: "idx_vav_attribute_id")
  @@map("variant_attribute_values")
}

// ──────────────────────────────────────────────────────────────
// Inventory (1:1 with product_variants)
// ──────────────────────────────────────────────────────────────

model Inventory {
  id        String   @id @default(uuid()) @db.Uuid
  variantId String   @unique @map("variant_id") @db.Uuid
  quantity  Int      @default(0)
  reserved  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

// ──────────────────────────────────────────────────────────────
// Cart
// ──────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  status    CartStatus @default(active)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId], map: "idx_carts_user_id")
  // Note: the original migration created a partial unique index
  // `uq_user_active_cart ON carts(user_id) WHERE status='active'`.
  // Prisma cannot express `WHERE` on indexes, so it's added as a
  // raw SQL step in the first migration. See prisma/migrations/*.
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId], map: "uq_cart_variant")
  @@index([cartId], map: "idx_cart_items_cart_id")
  @@map("cart_items")
}

// ──────────────────────────────────────────────────────────────
// Orders
// ──────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  customerId      String      @map("customer_id") @db.Uuid
  sellerId        String      @map("seller_id") @db.Uuid
  paymentId       String?     @map("payment_id") @db.Uuid
  status          OrderStatus @default(pending)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(15, 2)
  shippingName    String      @map("shipping_name") @db.VarChar(255)
  shippingPhone   String      @map("shipping_phone") @db.VarChar(20)
  shippingAddress String      @map("shipping_address")
  note            String?
  cancelledReason String?     @map("cancelled_reason")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer      User             @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  seller        User             @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Restrict)
  payment       Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  statusLogs    OrderStatusLog[]

  @@index([customerId], map: "idx_orders_customer_id")
  @@index([sellerId], map: "idx_orders_seller_id")
  @@index([status], map: "idx_orders_status")
  @@index([paymentId], map: "idx_orders_payment_id")
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  variantId   String   @map("variant_id") @db.Uuid
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(15, 2)
  productName String   @map("product_name") @db.VarChar(255)
  variantSku  String   @map("variant_sku") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model OrderStatusLog {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  fromStatus String?  @map("from_status") @db.VarChar(20)
  toStatus   String   @map("to_status") @db.VarChar(20)
  changedBy  String?  @map("changed_by") @db.Uuid
  note       String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changer  User? @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([orderId], map: "idx_order_status_logs_order_id")
  @@map("order_status_logs")
}

// ──────────────────────────────────────────────────────────────
// Payments & webhook events
// ──────────────────────────────────────────────────────────────

model Payment {
  id              String         @id @default(uuid()) @db.Uuid
  customerId      String         @map("customer_id") @db.Uuid
  amount          Decimal        @db.Decimal(15, 2)
  currency        String         @default("VND") @db.VarChar(3)
  status          PaymentStatus  @default(pending)
  gateway         PaymentGateway
  gatewayRef      String?        @map("gateway_ref") @db.VarChar(255)
  gatewayData     Json?          @map("gateway_data")
  idempotencyKey  String         @unique @map("idempotency_key") @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer User    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orders   Order[]

  @@index([customerId], map: "idx_payments_customer_id")
  @@index([gatewayRef], map: "idx_payments_gateway_ref")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

model WebhookEvent {
  id          String   @id @db.VarChar(255)
  gateway     String   @db.VarChar(20)
  eventType   String   @map("event_type") @db.VarChar(100)
  payload     Json
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@map("webhook_events")
}